# Copy to .env (never commit .env)
NODE_ENV=development
PORT=4000

# PostgreSQL (Supabase / Neon / local)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# For Supabase / many cloud DBs:
PGSSLMODE=require

# Required app config (see services/config.js)
APP_BASE_URL=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
FREE_MONTHLY_LIMIT=200
PRO_MONTHLY_LIMIT=5000
MAX_MESSAGES_PER_HOUR=50
MAX_MESSAGES_PER_MINUTE=0
MIN_DELAY_SECONDS=20
MAX_DELAY_SECONDS=90
MAX_RETRIES=3

JWT_SECRET=change-me-to-a-long-random-string
# JWT_EXPIRES_IN=7d

# Comma-separated admin emails (optional)
# ADMIN_EMAILS=you@example.com

# AI (pick one; use mock for local demo without keys)
AI_PROVIDER=mock
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# AI_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# Stripe (optional; omit for testing without billing)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PRO=

# Uploads & WhatsApp session (production paths often set on Render/VPS)
UPLOADS_DIR=
WHATSAPP_SESSION_PATH=
# WHATSAPP_HEADLESS=true
# PUPPETEER_EXECUTABLE_PATH=
